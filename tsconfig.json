{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "sourceMap": true,
    "rootDir": "",
    "strict": true /* enable all strict type-checking options */,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "./",
    /* Additional Checks */
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedParameters": true,
    "paths": {
      "@common/*": ["./common/*"]
    }
  }
}
